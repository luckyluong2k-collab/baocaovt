{
  "name": "viettelpost-telegram-bot",
  "version": "1.0.0",
  "description": "Bot theo doi van don Viettel Post va gui canh bao Telegram.",
  "main": "firebase-entry.js",
  "type": "commonjs",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "start": "node src/index.js",
    "check": "node scripts/run-check.js",
    "report:undelivered": "node scripts/send-undelivered-report.js",
    "test": "node --test tests/*.test.js",
    "capture:sample": "node scripts/capture-viettelpost-sample.js",
    "deploy:firebase": "firebase deploy --only functions",
    "firebase:login": "firebase login",
    "firebase:secrets": "node scripts/print-firebase-secret-commands.js"
  },
  "dependencies": {
    "firebase-functions": "^6.0.1",
    "firebase-admin": "^13.0.0"
  }
}
