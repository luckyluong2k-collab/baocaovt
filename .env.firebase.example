# File mau bien moi truong Firebase Functions.
# Khong dien token, mat khau, secret vao file nay.

STORAGE_DRIVER=firestore
USE_MOCK_DATA=true
ORDER_SOURCE=api
TELEGRAM_CHAT_ID=-1003931579210
TELEGRAM_DRY_RUN=false

VIETTELPOST_API_BASE_URL=
VIETTELPOST_USERNAME=
VIETTELPOST_CUSTOMER_ID=
VIETTELPOST_LOGIN_PATH=
VIETTELPOST_TOKEN_LOGIN_PATH=/user/loginVTP
VIETTELPOST_LIST_ORDERS_PATH=
VIETTELPOST_LIST_ORDERS_METHOD=GET
VIETTELPOST_LIST_ORDERS_BODY_JSON=
VIETTELPOST_LIST_ORDERS_DAYS_BACK=30
VIETTELPOST_ORDER_DETAIL_PATH=
VIETTELPOST_ORDER_DETAIL_METHOD=GET
VIETTELPOST_AUTH_HEADER=Token
VIETTELPOST_AUTH_SCHEME=raw
VIETTELPOST_FIELD_MAPPING_FILE=viettelpost-field-mapping.example.json

CHECK_INTERVAL_MINUTES=60
LATE_DELIVERY_DAYS=5
LATE_DELIVERY_LEVELS=5,7,10
NO_UPDATE_HOURS=48
MISSED_CALL_THRESHOLD=2
MISSED_CONTACT_SESSION_THRESHOLD=2
MISSED_CALL_DIFFERENT_DAYS_THRESHOLD=2
MISSED_CALL_ALERT_MODE=COUNT
MISSED_CONTACT_SESSION_MINUTES=5
FAILED_DELIVERY_THRESHOLD=2
COD_OVERDUE_DAYS=3
MASK_PHONE=false
TIMEZONE=Asia/Ho_Chi_Minh
PROTECT_READ_ENDPOINTS=true
ADMIN_RATE_LIMIT_SECONDS=60

# Doi thanh true neu muon Firebase gui bao cao don chua giao luc 08:00 moi ngay.
ENABLE_SCHEDULED_CHECK=false
SEND_DAILY_UNDELIVERED_REPORT=false
